{
  "expo": {
    "name": "MediCare_AI",
    "slug": "medicare-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "medicare-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medicare.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "MediCare AI needs access to your camera for skin analysis and report scanning.",
        "NSMicrophoneUsageDescription": "MediCare AI needs access to your microphone for voice assistant features."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0066FF",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "package": "com.medicare.ai"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0066FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1441575-bddf-4377-9990-cac5f7ddfe4f"
      }
    }
  }
}
